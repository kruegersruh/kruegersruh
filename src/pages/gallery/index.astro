---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import PageHeader from '@components/PageHeader.astro'
import type { PaginateFunction, Page } from 'astro'
import { getCollection } from "astro:content";
import { Card, Pagination } from 'accessible-astro-components'

// https://github.com/johny/astro-photo-gallery-example/

const gallery = await getCollection("gallery");
---

<DefaultLayout title="Fotogallerie">
  <PageHeader
      title="Fotogallerie"
    />
  <section class="mt-5 mb-12">
    <div class="container">
      <div class="p-8">
        <div class="mx-auto container max-w-(--breakpoint-sm) grid grid-cols-3 gap-10 text-center">
          {
            gallery.map((item) => (
              <Card
                imageComponent={item.data.cover}
                url={`/gallery/${item.id}`}
                title={item.data.title}
              >
              </Card>
            ))
          }
        </div>
      </div>
    </div>
  </section>
</DefaultLayout>
