---
import DefaultLayout from '../../layouts/DefaultLayout.astro'
import PageHeader from '../../components/PageHeader.astro'
import { Card, Media } from 'accessible-astro-components'
import { getCollection } from "astro:content";

// https://github.com/johny/astro-photo-gallery-example/

const albums = await getCollection("albums");
export async function getStaticPaths() {
  const albums = await getCollection("albums");
  
  const paths = Object.values(albums).map((album) => {
    return {
      params: {
        id: album.id,
      },
      props: {
        album,
      },
    };
  });

  return paths;
}

---

<DefaultLayout title="Fotogallerie">
  <PageHeader
      title="Fotogallerie"
    />
  <section class="mt-5 mb-12">
    <div class="container">
      <div class="p-8">
        <div class="mx-auto container max-w-(--breakpoint-sm) grid grid-cols-3 gap-10 text-center">
          {
            albums.map((item) => (
                <Card
                  imageComponent={item.data.cover}
                  url={`/gallery/${item.id}`}
                  title={item.data.title}
              >
              </Card>
            ))
          }
        </div>
      </div>
    </div>
  </section>
</DefaultLayout>
