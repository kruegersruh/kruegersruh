---
import DefaultLayout from '../layouts/DefaultLayout.astro'
import PageHeader from '../components/PageHeader.astro'
import { Media } from 'accessible-astro-components'
import { getCollection } from "astro:content";

// https://github.com/johny/astro-photo-gallery-example/
const albums = await getCollection("albums");
---

<DefaultLayout title="Fotogallerie">
  <PageHeader
      title="Fotogallerie"
    />
  <section class="mt-5 mb-12">
    <div class="container">
      <div class="p-8">
        <div class="mx-auto container max-w-(--breakpoint-sm) grid grid-cols-3 gap-10">
          {
            albums.map((item) => (
              <a
                href={`/gallery/${item.id}`}
                class="group transition-all mb-4 block"
              >
                <Media 
                  src={item.data.cover.src}
                  alt={item.data.title}
                  ratio="4:3"
                />
                <div class="mt-4 text-center">
                  <strong class="font-normal">{item.data.title}</strong>
                </div>
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </section>
</DefaultLayout>
