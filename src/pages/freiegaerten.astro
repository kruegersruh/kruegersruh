---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import PageHeader from '@components/PageHeader.astro'
import { Icon } from 'astro-icon/components'
import { Accordion, AccordionItem, Card, Pagination } from 'accessible-astro-components'
import type { PaginateFunction, Page } from 'astro'
import type { FunctionalComponent } from 'preact';
import { getCollection } from "astro:content";

const data = await fetch("https://opensheet.elk.sh/19ZpR0tDDIygHf2JtfKnFc6NznlwljL05erhcrY0ePUs/FREIE_GAERTEN").then((response) => response.json());

console.log(data);

---
<DefaultLayout title="Freie Gärten">
  <PageHeader
      title="Freie Gärten"
      subtitle="Hier finden sich aktuelle freie Gärten."
    />
    <section class="mt-5 mb-12"> 
      <div class="container">
        <table>
          <tr>
            <th>Adresse</th>
            <th>Größe</th>
            <th>Schätzsumme</th>
          </tr>
          {data.map((garden:any) => (
            <tr>
            <td>{garden.ADDRESS}</td>
            <td>{garden.SIZE}</td>
            <td>{garden.COST}</td>
            </tr>
          ))}
        </table>
      </div>
    </section>
  <section class="mt-5 mb-12"> 
    <div class="container">
      <Accordion>
        <AccordionItem
            title="Wie viel kostet ein Garten?"
            variant="chevron"
            open
            >
            <p>
             Als einmalige Kosten ergeben sich neben der gutachterlich festgestellten Schätzsumme auch ein Gesellschafteranteil für die Stromgesellschaft in Höhe von 820 €. Weiterhin fallen jährlich eine Pachtgebühr in Höhe von 0,50 Cent pro Quadratmeter, ein Vereinsbeitrag in Höhe von 110 €, ein Beitrag zur Feuer-, Einbruch- und Diebstahlversicherung (FED) in Höhe von 98 €, ein Beitrag zur Unfallversicherung in Höhe von 3,10 € und Stromkosten je nach Verbrauch an.
            </p>
          </AccordionItem>
          <AccordionItem
            title="Wie kann ich mich auf einen Garten bewerben?"
            variant="chevron"
            >
            <p>
              Lorem Ipsum.
            </p>
          </AccordionItem>
        </Accordion>
    </div>
  </section>
</DefaultLayout>

<style>
  td {
    text-align: center;
  }
</style>
