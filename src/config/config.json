{
  "site": {
    "title": "KGV Krügersruh e.V.",
    "base_url": "https://astroplate.netlify.app",
    "base_path": "/",
    "trailing_slash": false,
    "favicon": "/images/favicon.png",
    "logo_lightmode": "/images/logo_light.png",
    "logo_darkmode": "/images/logo_dark.png",
    "logo_width": "125",
    "logo_height": "200",
    "logo_text": "Kruegersruh"
  },

  "settings": {
    "search": false,
    "sticky_header": true,
    "theme_switcher": true,
    "default_theme": "light",
