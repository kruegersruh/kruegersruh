---
import { plainify } from "@/lib/utils/textConverter";
import ImageMod from "./ImageMod.astro";
import DynamicIcon from "@/helpers/DynamicIcon";

const { data } = Astro.props;
const { title, name, phone, mail, address, image } = data.data;
---

<div class="rounded bg-light p-8 text-center dark:bg-darkmode-light">
  {
    image && (
      <ImageMod
        class="mx-auto mb-6 rounded"
        src={image}
        alt={title}
        width={120}
        height={120}
        format="webp"
      />
    )
  }
  <h3 class="mb-4">
	{name}
  </h3>
  <h4 class="mb-4">
	{title}
  </h4>
  <p class="mb-5 text-center">
	{phone && <DynamicIcon className="inline-block" icon="MdLocalPhone" />} {phone}{phone && </br>}
	{mail && <DynamicIcon className="inline-block" icon="MdMail" />} {mail}{mail && </br>}
	{address && <DynamicIcon className="inline-block" icon="FaLocationDot" />} {address}{address && </br>}
  </p>
</div>
